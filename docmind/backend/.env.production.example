# Production environment for DocMind Backend
# Copy this file to .env.production and fill in real values

DATABASE_URL=sqlite+aiosqlite:///./docmind.db
GROQ_API_KEY=your_groq_api_key_here
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX=docmind-index
VECTOR_STORE_TYPE=faiss
VECTOR_EMBEDDING_TYPE=huggingface
FAISS_INDEX_PATH=/data/faiss_index
UPLOAD_DIR=/data/uploads
MAX_FILE_SIZE_MB=50
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RESULTS=5
LLM_MODEL=llama-3.1-8b-instant
EMBEDDING_MODEL=all-MiniLM-L6-v2
SECRET_KEY=change-this-to-a-long-random-secret-in-production
CORS_ORIGINS=["https://your-vercel-app.vercel.app","http://localhost:5173"]
